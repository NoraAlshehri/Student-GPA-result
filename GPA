class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()
        setContent {
            DrawStudentInformation()

            DrawStudentInformationV2(
                studentName = "Ahmed",
                studentAge = 19,
                studentGpa = 4.1,
                imageId =0
//                onNextClick
            )
        }
    }
}

@Composable
private fun DrawStudentInformationV2(
    studentName: String,
    studentAge: Int,
    studentGpa: Double,
    imageId: Int,
//   Do onNextClick: () -> Unit
    
) {
    Column(
        modifier = Modifier.fillMaxSize().padding(30.dp),
        horizontalAlignment = Alignment.CenterHorizontally,
        verticalArrangement = Arrangement.Center
    )
    {
        Text(
            text = "Student information",
            fontSize = 30.sp,
            fontStyle = FontStyle.Italic,
            fontWeight = FontWeight.Bold,
            fontFamily = FontFamily.Serif
        )

        Spacer(Modifier.height(20.dp))

        Text(
            "Student's name: $studentName",
            fontSize = 20.sp,
            textAlign = TextAlign.Left,
            fontFamily = FontFamily.Serif,
            modifier = Modifier.fillMaxWidth()

        )
        Text(
            "Student's age: $studentAge",
            fontSize = 20.sp,
            textAlign = TextAlign.Left,
            fontFamily = FontFamily.Serif,
            modifier = Modifier.fillMaxWidth()

        )
        Text(
            "Student's GPA: $studentGpa",
            fontSize = 20.sp,
            textAlign = TextAlign.Left,
            fontFamily = FontFamily.Serif,
            modifier = Modifier.fillMaxWidth()

        )
        Spacer(Modifier.height(20.dp))

        Image(
            painter = painterResource(id = imageId),
            contentDescription = "x",
            modifier = Modifier.size(140.dp)
        )
        Spacer(Modifier.height(20.dp))
        Button(
            onClick = { /*onNextClick*/ },
            colors = ButtonDefaults.buttonColors(
                containerColor = Color.Green,
                contentColor = Color.White
            )
        ) {
            Text("Next Student")
        }

    }
}

@Composable
private fun DrawStudentInformation() {
    var selectedIndex by remember { mutableStateOf(0) }
    val names = listOf("Ahmed", "Nasser", "Khalid")
    val ages = listOf(19, 18, 18)
    val gpas = listOf(4.1, 3.5, 2.0)

    val img = if (gpas[selectedIndex] > 3.0) R.drawable.pass
    else
        R.drawable.failed

    Spacer(Modifier.height(20.dp))

    DrawStudentInformationV2(
        studentName = names[selectedIndex],
        studentAge = ages[selectedIndex],
        studentGpa = gpas[selectedIndex],
        imageId = img,
    )
    Spacer(Modifier.height(40.dp))

    Spacer(Modifier.height(20.dp))

    val interactionSource = remember { MutableInteractionSource() }
    val isPressed by interactionSource.collectIsPressedAsState()

    // TODO - onClick tobe lambda way
    Button(onClick = {
            if (selectedIndex == names.indices.last) {
                selectedIndex = names.indices.first
            } else {
                selectedIndex += 1
            }
        },

                interactionSource = interactionSource,
        modifier = Modifier
            .graphicsLayer(
                scaleX = if (isPressed) 0.96f else 1f,
                scaleY = if (isPressed) 0.96f else 1f
            )
            .shadow(
                if (isPressed) 2.dp else 10.dp,
                shape = RoundedCornerShape(12.dp)
            ),
        shape = RectangleShape,
        content = {
            Text(
                text = "Next Student",
                fontSize = 22.sp
            )

        }
    )
}

